# TencentDB Agent Memory Gateway connection
TENCENTDB_GATEWAY_HOST=127.0.0.1
TENCENTDB_GATEWAY_PORT=8420

# Optional: set this if you enabled TDAI_GATEWAY_API_KEY on the Gateway
# TENCENTDB_GATEWAY_API_KEY=

# Gateway LLM credentials (used by start-gateway.py to launch the sidecar)
# Pick any OpenAI-compatible endpoint. Examples:
#   SiliconFlow: https://api.siliconflow.cn/v1
#   Tencent LKE: https://api.lkeap.cloud.tencent.com/v1
#   OpenAI:      https://api.openai.com/v1
TENCENTDB_LLM_API_KEY=sk-your-key-here
TENCENTDB_LLM_BASE_URL=https://api.siliconflow.cn/v1
TENCENTDB_LLM_MODEL=deepseek-v3
